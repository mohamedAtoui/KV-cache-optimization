{
  "model_name": "gptneo_mqa_tinystories",
  "architecture": "gpt_neo_mqa",
  "description": "GPTNeo decoder-only transformer with Multi-Query Attention for TinyStories dataset with L4 optimization",

  "model": {
    "vocab_size": 50257,
    "hidden_size": 256,
    "num_layers": 4,
    "num_heads": 8,
    "intermediate_size": 1024,
    "max_position_embeddings": 256,
    "dropout": 0.2,
    "position_embedding_type": "rope",
    "activation": "gelu",
    "layer_norm_epsilon": 1e-5,
    "initializer_range": 0.02,
    "tie_word_embeddings": true
  },

  "training": {
    "dataset": "tinystories",
    "train_samples": 30000,
    "val_samples": 5000,
    "batch_size": 64,
    "gradient_accumulation_steps": 4,
    "effective_batch_size": 256,
    "max_steps": 6000,
    "warmup_steps": 600,
    "learning_rate": 5e-5,
    "min_learning_rate": 1e-6,
    "lr_scheduler": "cosine",
    "weight_decay": 0.01,
    "gradient_clip": 0.5,
    "use_bf16": true,
    "optimizer": "adamw",
    "adam_beta1": 0.9,
    "adam_beta2": 0.999,
    "adam_epsilon": 1e-8,
    "max_seq_length": 256
  },

  "data": {
    "tokenizer": "gpt2",
    "dataset_name": "roneneldan/TinyStories",
    "dataset_config": "default",
    "text_column": "text",
    "streaming": false,
    "num_workers": 4,
    "prefetch_factor": 2,
    "pin_memory": true
  },

  "logging": {
    "log_dir": "../logs/gptneo_mqa_tinystories",
    "checkpoint_dir": "../checkpoints/gptneo_mqa_tinystories",
    "save_every_steps": 2000,
    "eval_every_steps": 1000,
    "log_every_steps": 50,
    "use_tensorboard": true,
    "use_wandb": false,
    "project_name": "gptneo-mqa-tinystories",
    "run_name": "gptneo_mqa_256_4l_l4_optimized"
  },

  "evaluation": {
    "eval_batch_size": 32,
    "eval_max_steps": 100,
    "generation_prompts": [
      "Once upon a time",
      "One day, a little girl",
      "In a big forest",
      "There was a happy dog"
    ],
    "generation_max_length": 100,
    "generation_temperature": 0.8,
    "generation_top_k": 50,
    "generation_top_p": 0.95
  },

  "hardware": {
    "device": "cuda",
    "gpu_type": "L4",
    "mixed_precision": "bf16",
    "compile_model": true,
    "ddp": false,
    "num_gpus": 1
  },

  "checkpointing": {
    "save_total_limit": 3,
    "save_best_only": false,
    "metric_for_best_model": "eval_loss",
    "greater_is_better": false,
    "load_best_model_at_end": true,
    "resume_from_checkpoint": null
  },

  "random_seed": 42,

  "notes": {
    "attention_type": "Multi-Query Attention (MQA)",
    "expected_params": "~12M parameters (4 layers, 44% fewer attention params than MHA)",
    "expected_training_time": "~40-55 mins on L4 (slightly faster than MHA)",
    "expected_train_ppl": "20-30 (similar to MHA)",
    "expected_val_ppl": "25-45 (minor degradation vs MHA acceptable)",
    "dataset_source": "TinyStories paper (Eldan & Li, 2023)",
    "optimization": "MQA reduces attention params and speeds up inference. Same successful hyperparameters as MHA (LR=5e-5, warmup=600)",
    "mqa_benefits": "Faster decoding, smaller KV cache, fewer parameters, good for inference optimization"
  }
}
